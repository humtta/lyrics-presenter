{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "formatter": {
    "enabled": true,
    "useEditorconfig": true
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },

  "assist": {
    "enabled": true,
    "actions": {
      "recommended": true
    }
  },

  "html": {
    "formatter": {
      "enabled": true
    }
  },

  "css": {
    "formatter": {
      "enabled": true
    }
  }
}
