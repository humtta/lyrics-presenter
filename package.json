{
  "name": "lyrics-presenter",
  "description": "Browser extension to present song lyrics in fullscreen",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",

  "scripts": {
    "format": "biome format --write .",
    "lint": "biome check .",
    "check": "npm run format && npm run lint",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "prepare": "wxt prepare"
  },

  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@wxt-dev/auto-icons": "^1.1.1",
    "typescript": "^6.0.3",
    "wxt": "^0.20.27"
  }
}
